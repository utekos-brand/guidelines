# OpenAI Secure MCP Tunnel local runtime config for utekos-brand.
# Copy to .env.tunnel.local and fill the two OpenAI values from Platform tunnel settings.
#
# ChatGPT app authentication: choose "No Authentication".
# The tunnel keeps the local MCP server private; this file is only for local tunnel-client runtime.

# Platform tunnel settings -> tunnel id.
CONTROL_PLANE_TUNNEL_ID=

# Runtime API key with Tunnels Read + Use for the tunnel.
CONTROL_PLANE_API_KEY=

# Dedicated target defaults.
OPENAI_TUNNEL_TARGET=eufemia
OPENAI_TUNNEL_PROFILE=utekos-brand-eufemia
OPENAI_TUNNEL_HEALTH_ADDR=127.0.0.1:8086
OPENAI_TUNNEL_MCP_COMMAND=node /Users/kristofferohnstadhjelmeland/utekos-brand/scripts/mcp/utekos-brand-eufemia-server.mjs
