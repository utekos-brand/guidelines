{
  "name": "utekos-brand-guidelines",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "a11y-color-contrast-mcp": "npx -y a11y-color-contrast-mcp",
    "tw-mcp": "npx -y tailwindcss-mcp-server",
    "canva-mcp": "npx -y @canva/cli@latest mcp",
    "spor-mcp": "npx -y @vygruppen/spor-mcp-server",
    "eufemia-mcp": "npx -y mcp-remote https://eufemia-mcp.eufemia.workers.dev/mcp",
    "mcp:brand-eufemia:doctor": "node scripts/mcp/doctor-utekos-brand-eufemia-server.mjs",
    "mcp:tunnel:bootstrap-env": "node scripts/mcp/openai-tunnel.mjs bootstrap-env",
    "mcp:tunnel:reuse-headless-auth": "node scripts/mcp/openai-tunnel.mjs reuse-headless-auth",
    "mcp:tunnel:check": "node scripts/mcp/openai-tunnel.mjs check",
    "mcp:tunnel:init:eufemia": "node scripts/mcp/openai-tunnel.mjs init --target eufemia",
    "mcp:tunnel:doctor:eufemia": "node scripts/mcp/openai-tunnel.mjs doctor --target eufemia",
    "mcp:tunnel:run:eufemia": "node scripts/mcp/openai-tunnel.mjs run --target eufemia",
    "mcp:tunnel:start:eufemia": "node scripts/mcp/openai-tunnel.mjs start --target eufemia",
    "mcp:tunnel:status:eufemia": "node scripts/mcp/openai-tunnel.mjs status --target eufemia",
    "mcp:tunnel:stop:eufemia": "node scripts/mcp/openai-tunnel.mjs stop --target eufemia",
    "mdn-mcp": "npx -y mcp-remote https://mcp.mdn.mozilla.net/",
    "next-devtools-mcp": "npx -y next-devtools-mcp@latest",
    "vercel-mcp": "npx -y https://mcp.vercel.com",
    "apify-mcp": "sh -c 'set -a; [ -f .env.local ] && . ./.env.local; set +a; APIFY_AUTH_TOKEN=${APIFY_TOKEN:-$APIFY_API_KEY}; if [ -z \"$APIFY_AUTH_TOKEN\" ]; then echo \"APIFY_TOKEN or APIFY_API_KEY is required\" >&2; exit 1; fi; APIFY_AUTH_HEADER=\"Bearer $APIFY_AUTH_TOKEN\"; export APIFY_AUTH_HEADER; npx -y mcp-remote \"https://mcp.apify.com/?tools=pattonholdings/color-contrast-auditor\" --header \"Authorization:${APIFY_AUTH_HEADER}\" --silent'",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "lint-staged": {
    "*": "prettier --write --ignore-unknown"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@dnb/eufemia": "^11.8.0",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@next/mdx": "^16.2.9",
    "@prettier/plugin-xml": "^3.4.2",
    "@swc/helpers": "0.5.15",
    "@types/mdx": "^2.0.14",
    "babel-plugin-react-compiler": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "glob": "13.0.6",
    "katex": "^0.17.0",
    "lucide-react": "^1.20.0",
    "next": "^16.2.9",
    "prettier-plugin-markdown-html": "^1.4.1",
    "prettier-plugin-rational-order": "^1.0.3",
    "prettier-plugin-yaml": "^1.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-external-links": "^3.0.0",
    "rehype-katex": "^7.0.1",
    "rehype-pretty-code": "^0.14.3",
    "rehype-slug": "^6.0.0",
    "rehype-starry-night": "^2.2.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-mdx-frontmatter": "^5.2.0",
    "remark-toc": "^9.0.0",
    "shadcn": "^4.12.0",
    "shared": "link:@dnb/eufemia/src/shared",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-mcp-server": "^0.1.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/typography": "^0.5.20",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.1",
    "prettier-plugin-powershell": "^2.1.5",
    "prettier-plugin-tailwindcss": "^0.7.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  }
}
